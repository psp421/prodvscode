# Force LF line endings for all ABAP/CDS source and XML files
# SAP XML parser expects LF — CRLF causes silent parse failures in abapgit

* text=auto

*.abap      text eol=lf
*.asddls    text eol=lf
*.asdcls    text eol=lf
*.asbdef    text eol=lf
*.xml       text eol=lf

# Binary assets — no conversion
*.png       binary
*.jpg       binary
*.gif       binary
*.pdf       binary
